{
  "name": "questura-v2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- node --import ./instrument.server.mjs ./node_modules/vite/bin/vite.js dev --port 3000",
    "build": "vite build && node ./scripts/copy-instrument.mjs",
    "preview": "vite preview",
    "test": "vitest run -c vitest.config.ts tests/unit",
    "test:watch": "vitest -c vitest.config.ts tests/unit",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "deps:unused": "knip",
    "deps:cruise": "depcruise --config .dependency-cruiser.cjs src",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@github/copilot": "^1.0.61",
    "@sentry/tanstackstart-react": "^10.58.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^0.577.0",
    "msw": "^2.13.4",
    "nitro": "npm:nitro-nightly@latest",
    "pino": "^10.3.1",
    "posthog-js": "^1.390.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "17.2.3",
    "husky": "^9.1.7",
    "knip": "^6.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.{yml,yaml}": [
      "prettier --write"
    ]
  }
}
