{
  "name": "questura-v2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- node --import ./instrument.server.mjs ./node_modules/vite/bin/vite.js dev --port 3000",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "build": "vite build && node ./scripts/copy-instrument.mjs",
    "preview": "vite preview",
    "test": "vitest run -c vitest.config.ts tests/unit",
    "test:watch": "vitest -c vitest.config.ts tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install --with-deps chromium",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:create": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:verify:runtime": "dotenv -e .env -- node --experimental-strip-types scripts/database/verify-prisma-runtime.mjs",
    "prisma:create:superadmin": "dotenv -e .env -- node --experimental-strip-types scripts/database/create-superadmin.ts",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "deps:unused": "knip",
    "deps:cruise": "depcruise --config .dependency-cruiser.cjs src",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "bullmq": "^5.75.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.577.0",
    "msw": "^2.13.4",
    "nitro": "npm:nitro-nightly@latest",
    "nodemailer": "^8.0.7",
    "pg": "8.21.0",
    "pino": "^10.3.1",
    "posthog-js": "^1.369.3",
    "rate-limiter-flexible": "^11.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "17.2.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "7.8.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.{yml,yaml}": [
      "prettier --write"
    ]
  }
}
